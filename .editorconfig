# EditorConfig for consistent coding style
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{py,md}]
indent_style = space
indent_size = 4

[*.{xml,vcxproj,sln}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
